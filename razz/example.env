# Copy to .env on razz (gitignored). Used by the Django web app and cloudflared.

SECRET_KEY=<secret django key>
DJANGO_ENV=production
TZ=America/Los_Angeles

# Cloudflare tunnel
TUNNEL_ID=<tunnel id>
TUNNEL_TOKEN=<tunnel token>

# Django -> Postgres on cube (Unraid), reached over Tailscale
PG_HOST=cube
PG_USER=nick
PG_PASS=<secret postgres password>
