# Copy to .env on thinkbox (gitignored). Read by prep-data.py.

# Register free at https://mobilitydatabase.org for US-wide GTFS coverage,
# then paste the refresh token here. Without it, prep-data.py can only use
# GTFS zips you drop into ./data/gtfs/ manually.
MOBILITY_DB_REFRESH_TOKEN=<mobility database refresh token>

# Optional overrides:
# MOTIS_TAG=2.8.3   # MOTIS Docker image tag (keep in sync with compose.yaml)
# NUM_DAYS=30       # timetable window in days
